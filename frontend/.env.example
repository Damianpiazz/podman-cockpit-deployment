# Medusa backend URL — internal Docker network address
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://medusa:9000

# Medusa publishable key — from Medusa admin dashboard
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_test

# Storefront base URL
NEXT_PUBLIC_BASE_URL=http://localhost

# Default region (ISO-2 lowercase)
NEXT_PUBLIC_DEFAULT_REGION=us

# Next.js revalidation secret
REVALIDATE_SECRET=CHANGE_ME_REVALIDATION_SECRET
