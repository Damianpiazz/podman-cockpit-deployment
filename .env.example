# ============================================================
# Environment Variables — Ecommerce Stack
# Copy to .env and replace values
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# --- Medusa Secrets (generate with: openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_JWT_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# --- Medusa API ---
MEDUSA_REVALIDATION_SECRET=CHANGE_ME_REVALIDATION_SECRET

# --- Storefront ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://medusa:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_test
